# Beta access gate — required to enter the app (quote values containing #)
VITE_ACCESS_CODE="Kv9#mPx7Lq4wRn2Zt8Bj5"

# Supabase (from project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Site URL for email confirmation redirects
VITE_SITE_URL=https://www.kalvio.org

# Feedback → your inbox via Web3Forms (https://web3forms.com — free tier)
# Create a form with your email, copy the access key here and in Vercel env.
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# Database password (local scripts only — npm run migrate:feedback, setup:db)
# SUPABASE_DB_PASSWORD=your-database-password

# Admin credentials (local scripts only — never expose in Vercel or the browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_DB_PASSWORD=your-database-password
